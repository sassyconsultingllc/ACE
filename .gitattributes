# Default: let Git detect text files
* text=auto

# Force LF in the repo for source files and JSON
*.c           text eol=lf
*.cpp         text eol=lf
*.h           text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.json        text eol=lf
*.py          text eol=lf
*.sh          text eol=lf
*.md          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf

# Keep CRLF for Windows scripts
*.bat         text eol=crlf
*.ps1         text eol=crlf

# Binary files
*.png         -text
*.jpg         -text
*.jpeg        -text
*.gif         -text
*.exe         -text
