<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" 
             Name="Sassy Browser" 
             Language="1033" 
             Version="2.0.0.0" 
             Manufacturer="Sassy Consulting LLC" 
             UpgradeCode="E8F5C9A2-4B3D-4F1E-9A8B-7C6D5E4F3A2B">
        
        <Package InstallerVersion="500" 
                 Compressed="yes" 
                 InstallScope="perUser"
                 Description="Pure Rust web browser with security-first design"
                 Comments="Installs Sassy Browser"
                 Manufacturer="Sassy Consulting LLC" />
        
        <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
        <MediaTemplate EmbedCab="yes" />
        
        <Feature Id="ProductFeature" Title="Sassy Browser" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
            <ComponentGroupRef Id="PhoneApp" />
            <ComponentRef Id="ApplicationShortcut" />
            <ComponentRef Id="DesktopShortcut" />
        </Feature>
        
        <Icon Id="SassyIcon" SourceFile="assets\icons\icon.ico" />
        <Property Id="ARPPRODUCTICON" Value="SassyIcon" />
        <Property Id="ARPHELPLINK" Value="https://onesassybrowser.com" />
        <Property Id="ARPURLINFOABOUT" Value="https://github.com/sassyconsultingllc/onesassybrowser" />
        
        <UIRef Id="WixUI_InstallDir" />
        <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
        
        <WixVariable Id="WixUILicenseRtf" Value="LICENSE.rtf" />
    </Product>

    <Fragment>
        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="LocalAppDataFolder">
                <Directory Id="INSTALLFOLDER" Name="SassyBrowser">
                    <Directory Id="PhoneAppDir" Name="phone-app" />
                </Directory>
            </Directory>
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="Sassy Browser" />
            </Directory>
            <Directory Id="DesktopFolder" Name="Desktop" />
        </Directory>
    </Fragment>

    <Fragment>
        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <Component Id="MainExecutable" Guid="*">
                <File Id="SassyBrowserExe" 
                      Source="target\release\sassy-browser.exe" 
                      KeyPath="yes">
                    <Shortcut Id="ExeShortcut"
                              Name="Sassy Browser"
                              Description="Secure web browser"
                              Icon="SassyIcon"
                              Advertise="yes" />
                </File>
            </Component>
            <Component Id="ConfigFiles" Guid="*">
                <File Id="DefaultTheme" Source="config\default_theme.toml" />
                <File Id="SyncConfig" Source="config\sync.toml" />
            </Component>
        </ComponentGroup>
        
        <ComponentGroup Id="PhoneApp" Directory="PhoneAppDir">
            <Component Id="PhoneAppHtml" Guid="*">
                <File Id="PhoneIndex" Source="phone-app\index.html" KeyPath="yes" />
            </Component>
            <Component Id="PhoneAppManifest" Guid="*">
                <File Id="PhoneManifest" Source="phone-app\manifest.json" KeyPath="yes" />
            </Component>
        </ComponentGroup>
        
        <DirectoryRef Id="ApplicationProgramsFolder">
            <Component Id="ApplicationShortcut" Guid="*">
                <Shortcut Id="StartMenuShortcut"
                          Name="Sassy Browser"
                          Description="Secure web browser"
                          Target="[INSTALLFOLDER]sassy-browser.exe"
                          WorkingDirectory="INSTALLFOLDER"
                          Icon="SassyIcon" />
                <RemoveFolder Id="CleanupStartMenu" On="uninstall" />
                <RegistryValue Root="HKCU" 
                               Key="Software\SassyBrowser" 
                               Name="installed" 
                               Type="integer" 
                               Value="1" 
                               KeyPath="yes" />
            </Component>
        </DirectoryRef>
        
        <DirectoryRef Id="DesktopFolder">
            <Component Id="DesktopShortcut" Guid="*">
                <Shortcut Id="DesktopShortcutLink"
                          Name="Sassy Browser"
                          Description="Secure web browser"
                          Target="[INSTALLFOLDER]sassy-browser.exe"
                          WorkingDirectory="INSTALLFOLDER"
                          Icon="SassyIcon" />
                <RegistryValue Root="HKCU"
                               Key="Software\SassyBrowser"
                               Name="desktop"
                               Type="integer"
                               Value="1"
                               KeyPath="yes" />
            </Component>
        </DirectoryRef>
    </Fragment>
</Wix>
