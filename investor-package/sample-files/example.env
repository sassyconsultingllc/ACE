# Sassy Browser Environment Configuration
# .env file demo

# Application
APP_NAME=SassyBrowser
APP_VERSION=2.0.0
APP_ENV=production

# Security
ENABLE_SANDBOX=true
ENABLE_TELEMETRY=false
GOOGLE_DEPENDENCIES=0

# Network
API_TIMEOUT=30000
MAX_CONNECTIONS=6

# Paths
DATA_DIR=/home/user/.sassy
CACHE_DIR=/home/user/.sassy/cache
LOG_LEVEL=info

# Feature Flags
FEATURE_DEVTOOLS=true
FEATURE_REST_CLIENT=true
FEATURE_CLOUD_SYNC=false
